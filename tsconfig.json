{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Benchmarking Library",
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "lib": [
      "ESNext", "DOM.Iterable", "ESNext.Iterator", "DOM"
    ],
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "strict": true,
    "esModuleInterop": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "alwaysStrict": true,
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "./build",
    "rootDir": "./.",
    "forceConsistentCasingInFileNames": true,
    "importHelpers": false,
    "declaration": true,
    "declarationMap": true,
    "pretty": true,
    "skipLibCheck": true,
    "incremental": true,
    "types": ["@types/node"],
  },
  "exclude": ["dist", "node_modules", "coverage", "docs"],
  "include": [
    "src/**/*",
    "src/index.ts",
    "tests/**/*.ts",
    "bin/**/*.ts"
  ],
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "esm": true,
  }
}
